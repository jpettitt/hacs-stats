# Copy to `.env` and fill in. `.env` is gitignored.
# Loaded automatically by tsx via `--env-file` (set in each app's `dev` script).

# GitHub PAT — needs `public_repo` scope. No write access required.
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# Path to the SQLite file. Defaults to ./data/dev.db in dev.
# Prod sets this to /var/lib/hacs-stats/hacs-stats.db via the systemd unit.
DATABASE_PATH=./data/dev.db

# Port for the web server. Defaults to 3000.
PORT=3000
