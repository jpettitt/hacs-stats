# Copy to `.env` and fill in. `.env` is gitignored.
# Loaded automatically by tsx via `--env-file` (set in each app's `dev` script).

# GitHub PAT (classic). No scopes needed — an unscoped token still gives the
# 5000/hr authenticated rate limit, which is what we actually want from it.
# Create at https://github.com/settings/tokens → "Generate new (classic)".
# REQUIRED for Phase 3 (GraphQL needs auth, REST releases at 60/hr unauth is
# too low to be useful).
GITHUB_TOKEN=

# Path to the SQLite file. Default: <repo-root>/data/dev.db (via
# resolveDatabasePath in @hacs-stats/db, repo-root anchored not CWD-relative).
# Prod sets this to /var/lib/hacs-stats/hacs-stats.db via the systemd unit.
DATABASE_PATH=

# Port for the web server. Defaults to 3000.
PORT=3000

# --- Dev / debugging knobs (all optional) -----------------------------------
# Stop after this many repos in the Phase 3 steps. Useful when iterating —
# the full ~3300-repo run takes ~10 min; SCRAPE_LIMIT=20 finishes in seconds.
# SCRAPE_LIMIT=20

# Skip the HACS default-list fetch + hacs.json passes. Lets you re-run the
# Phase 3 metadata/releases steps without re-fetching the catalog.
# SKIP_DEFAULTS=1

# Concurrency knobs (defaults shown).
# MANIFEST_CONCURRENCY=12
# RELEASES_CONCURRENCY=12
