{
  "name": "@hacs-stats/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env --import tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hacs-stats/db": "workspace:*",
    "@hacs-stats/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.16"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
