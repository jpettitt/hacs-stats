# /etc/caddy/Caddyfile on the VPS.
#
# The publicly-trusted certificate is served by Cloudflare's edge; this origin
# uses a Caddy-issued self-signed cert (`tls internal`). Cloudflare's SSL/TLS
# mode must be set to "Full" — NOT "Full (strict)" — so CF accepts the
# self-signed cert without trying to verify it against a public CA.
#
# Why self-signed instead of a CF Origin Cert:
#   - Zero dashboard steps; nothing to download, drop on disk, or rotate.
#   - Caddy auto-renews the internal cert; no human in the loop.
#   - Trade-off: CF can't detect an in-flight MITM between CF and origin.
#     Acceptable for a public read-only stats site.

{
	# Bind every site to BOTH IPv4 and IPv6. Without this, Caddy's default
	# resolves to just `[::]` on most Linux distros; when the kernel has
	# net.ipv6.bindv6only=1 (Debian/Ubuntu default in some configurations)
	# IPv4 connections can't piggyback on the v6 socket and Cloudflare
	# (which prefers v4 to origins) hits connection-refused.
	default_bind 0.0.0.0 ::
}

hacs-stats.dev {
	tls internal

	encode zstd gzip

	# Reverse proxy to the Node app on localhost. The Node process never binds
	# to a public interface. header_up MUST live inside reverse_proxy — at
	# the site-block level it's a parse error and Caddy silently falls back
	# to the default welcome page on the rest of the host.
	reverse_proxy 127.0.0.1:3000 {
		# Hand the real client IP through to the app for logs / rate limits.
		# CF puts it in CF-Connecting-IP; we forward as X-Real-IP since
		# that's the conventional name downstream code looks for.
		header_up X-Real-IP {http.request.header.CF-Connecting-IP}
	}

	# Log via systemd's journal — `journalctl -u caddy -f` is the live tail.
	# Avoids the perms dance of having Caddy create files under /var/log
	# (it runs as the `caddy` user, which needs explicit ownership of any
	# directory it writes to). JSON format keeps the structure for jq.
	log {
		output stderr
		format json
	}
}

# .com → .dev redirect. CF page-rule handles this at the edge too, but the
# server-side fallback covers the case where CF rules are disabled or someone
# hits the origin directly.
hacs-stats.com {
	tls internal
	redir https://hacs-stats.dev{uri} 308
}
