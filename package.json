{
  "name": "hacs-stats",
  "version": "0.0.0",
  "private": true,
  "description": "Unofficial usage stats for HACS — Home Assistant Community Store.",
  "author": "John Pettitt",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev:web": "pnpm --filter @hacs-stats/web dev",
    "dev:scraper": "pnpm --filter @hacs-stats/scraper dev",
    "migrate": "node --import tsx scripts/migrate.ts",
    "seed": "node --import tsx scripts/seed.ts",
    "discover": "node --import tsx scripts/discover.ts",
    "discover:bands": "node --import tsx scripts/discover-bands.ts",
    "backfill:queue": "node --import tsx scripts/backfill-queue.ts",
    "backfill:release-titles": "node --import tsx scripts/backfill-release-titles.ts",
    "sweep:queue": "node --import tsx scripts/sweep-queue.ts"
  },
  "dependencies": {
    "@hacs-stats/db": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
